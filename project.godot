; Engine configuration file.
; Scooter Hustle - arcade endless runner prototype (Godot 4.x)
;
; This file is normally generated by the Godot editor, but it is plain text
; so we can author it by hand. Open the project folder with Godot 4.3+ and it
; will import everything automatically.

config_version=5

[application]

config/name="Scooter Hustle"
config/description="An arcade endless runner set in chaotic Philippine traffic."
run/main_scene="res://ui/MainMenu.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[autoload]

; GameData is a global singleton (autoload). It is always available from any
; script simply by typing "GameData". It stores coins, unlocked scooters and
; handles saving / loading.
GameData="*res://systems/GameData.gd"
AudioManager="*res://systems/AudioManager.gd"
MissionManager="*res://systems/MissionManager.gd"
Desktop="*res://systems/Desktop.gd"

[display]

; LANDSCAPE PC build. 1280x720 is a comfortable default desktop window.
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
; Landscape on handheld too (this branch is the PC/landscape version).
window/handheld/orientation=0
; "expand" fills any window aspect (the HUD anchors keep their corners, the 3D
; camera just shows more/less to the sides) - so it scales on any monitor.
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

; --- Custom input actions -------------------------------------------------
; We only need two actions for testing on a keyboard. On a phone the player
; swipes instead (handled in Player.gd).

move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194319,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":65,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
move_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194321,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":68,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[input_devices]

; Let mouse clicks act as touches so swipe controls can be tested on a PC by
; click-dragging left or right.
pointing/emulate_touch_from_mouse=true

[rendering]

; Desktop uses the higher-quality Forward+ renderer; phones keep the lighter
; Mobile renderer, and the web build uses Compatibility (WebGL2).
renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
renderer/rendering_method.web="gl_compatibility"
; Android GPUs need ETC2/ASTC compressed textures (fixes the export warning).
textures/vram_compression/import_etc2_astc=true
; Crisper textures at oblique angles (road/buildings) + MSAA edges on desktop.
textures/default_filters/anisotropic_filtering_level=3
anti_aliasing/quality/msaa_3d=2
